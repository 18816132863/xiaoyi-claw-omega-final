{
  "version": "2.9.3",
  "name": "小艺 Claw 终极星空鸽子王",
  "architecture": "六层核心架构 L1-L6 (固定不变) + 文件保护模块深度整合",
  "upload_mode": "full_upload",
  "last_updated": "2026-04-11T09:34:00+08:00",
  
  "architecture_diagram": {
    "L1": "核心认知层 → 身份、规则、引导、配置",
    "L2": "记忆上下文层 → 记忆存储、检索、日记",
    "L3": "任务编排层 → 路由、工作流、调度、状态机",
    "L4": "能力执行层 → 技能执行、结果验证、健康检查",
    "L5": "稳定治理层 → 安全、权限、审计、文件保护",
    "L6": "基础设施层 → 路径、插件、性能、注册表"
  },
  
  "layer_integration": {
    "description": "各层之间的调用关系和数据流向",
    "flow": {
      "request_flow": "用户请求 → L1解析 → L3路由 → L4执行 → L5验证 → 返回结果",
      "protection_flow": "删除请求 → L5文件保护 → 人工确认 → L6执行 → L5审计日志",
      "memory_flow": "L1触发词 → L2加载记忆 → L3编排 → L4执行 → L2存储结果"
    }
  },
  
