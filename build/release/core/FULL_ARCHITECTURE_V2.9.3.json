  "call_coordination": {
    "description": "层间调用协调规则",
    "rules": [
      "L1 可以调用所有层 (触发)",
      "L2 只能调用 L6 (查找技能)",
      "L3 可以调用 L2, L4, L5, L6",
      "L4 可以调用 L2, L5",
      "L5 可以调用 L2, L6",
      "L6 可以调用 L2, L5",
      "所有删除操作必须经过 L5/file_guardian.py",
      "所有敏感操作必须经过 L5/security.py",
      "所有操作必须记录到 L5/audit.py"
