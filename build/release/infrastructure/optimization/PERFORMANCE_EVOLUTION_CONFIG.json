{
  "version": "1.0.0",
  "lastUpdated": "2026-04-06T22:00:00+08:00",
  "description": "性能进化系统配置",

  "global": {
    "enabled": true,
    "auto_evolve": true,
    "auto_optimize": true,
    "auto_predict": true,
    "require_confirmation_for_high_risk": true
  },

  "sensor": {
    "enabled": true,
    "adaptive_sampling": true,
    "sampling": {
      "normal_interval": 60,
      "warning_interval": 10,
      "critical_interval": 1
    },
    "metrics": {
      "system": ["cpu_usage", "memory_usage", "disk_usage", "network_io"],
      "application": ["response_time", "throughput", "error_rate", "queue_size"],
      "business": ["active_users", "request_count", "success_rate"],
      "custom": ["token_usage", "skill_usage", "context_size"]
    },
    "anomaly_detection": {
      "enabled": true,
      "methods": ["threshold", "trend", "change_point", "pattern"],
      "sensitivity": 0.8
    }
  },

  "analyzer": {
    "enabled": true,
    "analysis_types": {
      "bottleneck": {
        "enabled": true,
        "dimensions": ["cpu", "memory", "io", "network", "application"]
      },
      "root_cause": {
        "enabled": true,
        "methods": ["correlation", "causal", "trace"]
      },
      "trend": {
        "enabled": true,
        "window": 3600
      },
      "pattern": {
        "enabled": true,
        "patterns": ["degradation", "spike", "cycle", "anomaly"]
      }
    },
    "output_interval": 60
  },

  "optimizer": {
    "enabled": true,
    "auto_tune": true,
    "optimization_types": {
      "parameter": {
        "enabled": true,
        "method": "bayesian_optimization",
        "parameters": ["cache_size", "thread_pool", "timeout", "retry"],
        "max_iterations": 100
      },
      "config": {
        "enabled": true,
        "method": "reinforcement_learning",
        "configs": ["routing", "cache_policy", "load_balance"],
        "learning_rate": 0.1
      },
      "resource": {
        "enabled": true,
        "method": "demand_based",
        "resources": ["cpu", "memory", "connections"],
        "adjust_interval": 300
      },
      "architecture": {
        "enabled": true,
        "method": "pattern_matching",
        "patterns": ["caching", "async", "sharding", "replication"]
      }
    },
    "constraints": {
      "stability_first": true,
      "max_change_per_iteration": 0.1,
      "rollback_enabled": true
    }
  },

  "predictor": {
    "enabled": true,
    "models": {
      "linear": {
        "enabled": true,
        "horizon": 86400,
        "accuracy_threshold": 0.7
      },
      "time_series": {
        "enabled": true,
        "horizon": 604800,
        "accuracy_threshold": 0.75
      },
      "ml": {
        "enabled": true,
        "horizon": 2592000,
        "accuracy_threshold": 0.8
      }
    },
    "predictions": {
      "performance_trend": {
        "enabled": true,
        "metrics": ["response_time", "throughput", "error_rate"]
      },
      "capacity": {
        "enabled": true,
        "resources": ["storage", "compute", "bandwidth"],
        "threshold": 80
      },
      "issues": {
        "enabled": true,
        "patterns": ["degradation", "exhaustion", "failure"]
      }
    }
  },

  "decider": {
    "enabled": true,
    "decision_rules": [
      {
        "condition": "performance_drop > 20%",
        "action": "immediate_optimize",
        "priority": "P0"
      },
      {
        "condition": "predicted_issue within 24h",
        "action": "preventive_optimize",
        "priority": "P1"
      },
      {
        "condition": "resource_pressure > 80%",
        "action": "scale_resources",
        "priority": "P1"
      },
      {
        "condition": "optimization_risk > medium",
        "action": "require_confirmation",
        "priority": "P2"
      }
    ],
    "risk_assessment": {
      "enabled": true,
      "factors": ["impact_scope", "rollback_difficulty", "historical_success"]
    }
  },

  "executor": {
    "enabled": true,
    "execution_modes": {
      "immediate": {
        "enabled": true,
        "max_concurrent": 1
      },
      "scheduled": {
        "enabled": true,
        "default_schedule": "0 2 * * *"
      },
      "gradual": {
        "enabled": true,
        "step_size": 0.1,
        "step_interval": 60
      },
      "canary": {
        "enabled": true,
        "canary_ratio": 0.1,
        "monitor_duration": 300
      }
    },
    "safeguards": {
      "create_checkpoint": true,
      "monitor_during_execution": true,
      "auto_rollback_on_failure": true,
      "max_execution_time": 600
    }
  },

  "learner": {
    "enabled": true,
    "learning_types": {
      "experience": {
        "enabled": true,
        "collect_cases": true,
        "extract_patterns": true
      },
      "feedback": {
        "enabled": true,
        "collect_feedback": true,
        "adjust_strategies": true
      },
      "transfer": {
        "enabled": true,
        "identify_similar": true,
        "apply_strategies": true
      }
    },
    "model_update": {
      "enabled": true,
      "update_interval": 86400,
      "validation_required": true
    }
  },

  "notification": {
    "enabled": true,
    "events": {
      "optimization_started": {
        "notify": true,
        "level": "info"
      },
      "optimization_completed": {
        "notify": true,
        "level": "info"
      },
      "optimization_failed": {
        "notify": true,
        "level": "error"
      },
      "prediction_alert": {
        "notify": true,
        "level": "warning"
      },
      "evolution_milestone": {
        "notify": true,
        "level": "info"
      }
    }
  },

  "targets": {
    "response_time": {
      "current": 2000,
      "target": 500,
      "unit": "ms"
    },
    "throughput": {
      "current": 100,
      "target": 1000,
      "unit": "req/s"
    },
    "resource_efficiency": {
      "current": 50,
      "target": 80,
      "unit": "%"
    },
    "token_efficiency": {
      "current": 100,
      "target": 50,
      "unit": "%"
    }
  }
}
