      "violation_levels": {
        "CRITICAL": "跳过 L1 Core 规则读取",
        "HIGH": "跳过 L2 Memory 或 L3 Orchestration",
        "MEDIUM": "跳过 L4/L5/L6 或违反 IO 契约",
        "LOW": "缺少执行轨迹"
      },
      "auto_improvement": {
        "enabled": true,
        "trigger_on_violation": true,
        "analyze_patterns": true,
        "generate_fixes": true,
        "auto_apply_safe_fixes": true,
        "auto_upgrade_rule": true,
        "max_auto_fixes_per_day": 10
      }
