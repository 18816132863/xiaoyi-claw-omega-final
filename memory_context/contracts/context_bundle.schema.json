{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContextBundle",
  "type": "object",
  "required": ["task_id", "profile", "sources", "token_count", "built_at"],
  "properties": {
    "task_id": {"type": "string"},
    "profile": {"type": "string"},
    "intent": {"type": "string"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "content", "relevance"],
        "properties": {
          "type": {"enum": ["session", "memory", "document", "skill", "rule", "report"]},
          "content": {"type": "string"},
          "relevance": {"type": "number"},
          "source_id": {"type": "string"}
        }
      }
    },
    "token_count": {"type": "integer"},
    "token_budget": {"type": "integer"},
    "conflicts_resolved": {"type": "array", "items": {"type": "object"}},
    "priority_order": {"type": "array", "items": {"type": "string"}},
    "built_at": {"type": "string", "format": "date-time"}
  }
}
