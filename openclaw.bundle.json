{
  "name": "xiaoyi-claw-omega-final",
  "version": "7.2.0",
  "description": "V7.2.0 六层架构核心引擎 - 统一入口、三条主链、自动运行机制",
  "author": "18816132863",
  "license": "MIT-0",
  "targets": {
    "openclaw": ">=1.0.0"
  },
  "entrypoints": {
    "skill": "./SKILL.md"
  },
  "files": [
    "**/*.md",
    "**/*.py",
    "**/*.json"
  ],
  "exclude": [
    "node_modules/**",
    "__pycache__/**",
    ".git/**",
    "repo/**",
    "archive/**",
    "plugins/**",
    "logs/**",
    "cache/**",
    "memory_context/index/*.gz",
    "memory_context/ontology/**",
    "memory_context/data/**",
    "memory_context/archive/**",
    "memory_context/ecommerce/**",
    "memory_context/system/**",
    "memory_context/scenarios/**",
    "memory_context/session-summaries/**",
    "memory_context/projects/**",
    "memory_context/groups/**",
    "memory_context/feedback/**",
    "memory_context/cache/**",
    "memory_context/policies/**",
    "memory_context/adapters/**",
    "memory_context/contracts/**",
    "memory_context/vector/*.md",
    "memory_context/vector/*.sh",
    "memory_context/vector/docker-compose.yml",
    "memory_context/vector/test_*.py",
    "memory_context/vector/quick_start*.py",
    "skills/*/dist/**",
    "skills/*/__pycache__/**",
    "skills/*/node_modules/**",
    "skills/*/.git/**",
    "skills/*/tests/**",
    "skills/*/examples/**",
    "skills/*/docs/**",
    "skills/canvas-design/canvas-fonts/**",
    "reports/history/**",
    "docs/archives/**",
    "*.pdf",
    "*.tar.gz",
    "*.zip",
    "*.bak",
    "*.backup"
  ],
  "size_limit": "4MB",
  "features": [
    "六层架构核心代码",
    "三条主链完整实现",
    "自动运行机制",
    "统一巡检器",
    "Metrics 系统",
    "守护进程管理器"
  ],
  "layers": {
    "L1_core": "认知系统、事件系统、状态契约",
    "L2_memory_context": "上下文构建、检索系统、会话管理",
    "L3_orchestration": "工作流引擎、执行控制、状态管理",
    "L4_execution": "技能路由器、加载器、沙箱、审计",
    "L4_skills": "技能注册表、生命周期、策略",
    "L5_governance": "策略引擎、预算管理、风险管理",
    "L6_infrastructure": "守护进程、融合引擎、自动化"
  },
  "main_chains": {
    "lifecycle": "InstallManager → SkillRegistry → SkillRouter",
    "recovery": "FallbackPolicy → RollbackManager → WorkflowEngine",
    "metrics": "Benchmarks → EvaluationAggregator → PolicyEngine"
  }
}
