{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Registry",
  "description": "行业域注册表，定义不同领域的策略与agent组合",
  "type": "object",
  "properties": {
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["domain_id", "domain_name", "compliance_level"],
        "properties": {
          "domain_id": {
            "type": "string",
            "description": "领域唯一标识符",
            "pattern": "^domain_[a-z_]+$"
          },
          "domain_name": {
            "type": "string",
            "description": "领域名称"
          },
          "description": {
            "type": "string",
            "description": "领域描述"
          },
          "allowed_agent_suite": {
            "type": "array",
            "description": "允许的agent套件",
            "items": {
              "type": "string"
            }
          },
          "restricted_actions": {
            "type": "array",
            "description": "禁止的动作",
            "items": {
              "type": "object",
              "properties": {
                "action": { "type": "string" },
                "reason": { "type": "string" },
                "severity": { "type": "string", "enum": ["warning", "error", "block"] }
              }
            }
          },
          "required_validators": {
            "type": "array",
            "description": "必需的验证器",
            "items": {
              "type": "object",
              "properties": {
                "validator_id": { "type": "string" },
                "phase": { "type": "string", "enum": ["pre", "during", "post"] },
                "required": { "type": "boolean", "default": true }
              }
            }
          },
          "default_citation_mode": {
            "type": "string",
            "description": "默认引用模式",
            "enum": ["strict", "moderate", "relaxed"],
            "default": "moderate"
          },
          "compliance_level": {
            "type": "string",
            "description": "合规级别",
            "enum": ["standard", "high", "strict", "maximum"],
            "default": "standard"
          },
          "risk_disclosure_required": {
            "type": "boolean",
            "description": "是否需要风险披露",
            "default": false
          },
          "uncertainty_expression_level": {
            "type": "string",
            "description": "不确定性表达级别",
            "enum": ["minimal", "standard", "strong", "maximum"],
            "default": "standard"
          },
          "audit_level": {
            "type": "string",
            "description": "审计级别",
            "enum": ["basic", "standard", "detailed", "comprehensive"],
            "default": "standard"
          },
          "approval_requirements": {
            "type": "object",
            "description": "审批要求",
            "properties": {
              "for_actions": {
                "type": "array",
                "items": { "type": "string" }
              },
              "approvers": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "keywords": {
            "type": "array",
            "description": "领域关键词",
            "items": { "type": "string" }
          },
          "fallback_domain": {
            "type": "string",
            "description": "回退领域"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "domain_combinations": {
      "type": "array",
      "description": "领域组合规则",
      "items": {
        "type": "object",
        "properties": {
          "combination_id": { "type": "string" },
          "domains": {
            "type": "array",
            "items": { "type": "string" }
          },
          "primary_domain": { "type": "string" },
          "compatibility_rules": { "type": "object" }
        }
      }
    }
  },
  "examples": [
    {
      "domain_id": "domain_legal",
      "domain_name": "法律",
      "description": "法律相关事务处理",
      "allowed_agent_suite": ["legal_review", "contract_analysis", "risk_assessment"],
      "restricted_actions": [
        { "action": "provide_legal_conclusion", "reason": "不可冒充律师", "severity": "block" },
        { "action": "guarantee_legal_outcome", "reason": "不可保证法律结果", "severity": "block" },
        { "action": "replace_licensed_service", "reason": "不可替代持证法律服务", "severity": "block" }
      ],
      "required_validators": [
        { "validator_id": "citation_checker", "phase": "post", "required": true },
        { "validator_id": "disclaimer_checker", "phase": "post", "required": true }
      ],
      "default_citation_mode": "strict",
      "compliance_level": "maximum",
      "risk_disclosure_required": true,
      "uncertainty_expression_level": "maximum"
    },
    {
      "domain_id": "domain_finance",
      "domain_name": "金融",
      "description": "金融相关事务处理",
      "allowed_agent_suite": ["data_analysis", "risk_comparison", "budget_planning"],
      "restricted_actions": [
        { "action": "provide_investment_advice", "reason": "不可装成持牌投顾", "severity": "block" },
        { "action": "guarantee_returns", "reason": "不可保证收益", "severity": "block" },
        { "action": "recommend_stocks", "reason": "不可无依据荐股", "severity": "block" }
      ],
      "required_validators": [
        { "validator_id": "source_credibility", "phase": "pre", "required": true },
        { "validator_id": "timeliness_checker", "phase": "pre", "required": true }
      ],
      "default_citation_mode": "strict",
      "compliance_level": "strict",
      "risk_disclosure_required": true
    },
    {
      "domain_id": "domain_healthcare",
      "domain_name": "医疗健康",
      "description": "医疗健康相关事务处理",
      "allowed_agent_suite": ["info_organizer", "literature_search"],
      "restricted_actions": [
        { "action": "provide_diagnosis", "reason": "不可提供诊断", "severity": "block" },
        { "action": "prescribe_medication", "reason": "不可开处方", "severity": "block" },
        { "action": "replace_medical_advice", "reason": "不可替代医疗建议", "severity": "block" }
      ],
      "compliance_level": "maximum",
      "risk_disclosure_required": true
    },
    {
      "domain_id": "domain_operations",
      "domain_name": "运营",
      "description": "运营和项目管理",
      "allowed_agent_suite": ["sop_generator", "project_tracker", "task_breakdown", "review_assistant"],
      "default_citation_mode": "moderate",
      "compliance_level": "standard"
    },
    {
      "domain_id": "domain_research",
      "domain_name": "研究",
      "description": "研究和分析",
      "allowed_agent_suite": ["literature_review", "data_analysis", "report_generator"],
      "default_citation_mode": "strict",
      "compliance_level": "high"
    },
    {
      "domain_id": "domain_content",
      "domain_name": "内容创作",
      "description": "内容创作和编辑",
      "allowed_agent_suite": ["writer", "editor", "translator"],
      "default_citation_mode": "relaxed",
      "compliance_level": "standard"
    }
  ]
}
