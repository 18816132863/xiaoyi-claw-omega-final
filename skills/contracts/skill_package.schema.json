{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skill_package.schema.json",
  "title": "Skill Package Schema",
  "description": "正式 Skill Package 定义",
  "type": "object",
  "required": [
    "skill_id",
    "name",
    "version",
    "description",
    "entry_point",
    "input_schema",
    "output_schema",
    "status"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "description": "技能唯一标识符",
      "pattern": "^[a-z0-9_]+$"
    },
    "name": {
      "type": "string",
      "description": "技能名称",
      "minLength": 1,
      "maxLength": 100
    },
    "version": {
      "type": "string",
      "description": "语义化版本号",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9]+)?$"
    },
    "description": {
      "type": "string",
      "description": "技能描述",
      "minLength": 1,
      "maxLength": 500
    },
    "entry_point": {
      "type": "string",
      "description": "入口点（模块路径或可执行路径）"
    },
    "input_schema": {
      "type": "object",
      "description": "输入参数 Schema"
    },
    "output_schema": {
      "type": "object",
      "description": "输出结果 Schema"
    },
    "dependencies": {
      "type": "array",
      "description": "依赖的其他技能",
      "items": {
        "type": "object",
        "required": ["skill_id", "version_range"],
        "properties": {
          "skill_id": {
            "type": "string",
            "description": "依赖技能 ID"
          },
          "version_range": {
            "type": "string",
            "description": "版本范围（如 ^1.0.0, >=2.0.0 <3.0.0）"
          },
          "optional": {
            "type": "boolean",
            "description": "是否可选依赖",
            "default": false
          }
        }
      },
      "default": []
    },
    "compatible_profiles": {
      "type": "array",
      "description": "兼容的执行配置",
      "items": {
        "type": "string"
      },
      "default": ["default"]
    },
    "compatible_runtime_versions": {
      "type": "array",
      "description": "兼容的运行时版本",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "status": {
      "type": "string",
      "description": "技能状态",
      "enum": ["draft", "active", "deprecated", "retired"],
      "default": "active"
    },
    "health_status": {
      "type": "string",
      "description": "健康状态",
      "enum": ["healthy", "degraded", "unhealthy", "unknown"],
      "default": "unknown"
    },
    "author": {
      "type": "string",
      "description": "作者"
    },
    "license": {
      "type": "string",
      "description": "许可证"
    },
    "homepage": {
      "type": "string",
      "description": "主页 URL"
    },
    "repository": {
      "type": "string",
      "description": "代码仓库 URL"
    },
    "keywords": {
      "type": "array",
      "description": "关键词",
      "items": {
        "type": "string"
      }
    },
    "category": {
      "type": "string",
      "description": "分类"
    },
    "tags": {
      "type": "array",
      "description": "标签",
      "items": {
        "type": "string"
      }
    },
    "timeout_ms": {
      "type": "integer",
      "description": "超时时间（毫秒）",
      "default": 30000,
      "minimum": 1000,
      "maximum": 300000
    },
    "retry_policy": {
      "type": "object",
      "description": "重试策略",
      "properties": {
        "max_retries": {
          "type": "integer",
          "default": 3
        },
        "retry_delay_ms": {
          "type": "integer",
          "default": 1000
        },
        "backoff_multiplier": {
          "type": "number",
          "default": 2.0
        }
      }
    },
    "rate_limit": {
      "type": "object",
      "description": "速率限制",
      "properties": {
        "requests_per_minute": {
          "type": "integer"
        },
        "requests_per_hour": {
          "type": "integer"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "扩展元数据"
    }
  },
  "additionalProperties": true
}
